# ── Tax Code Reader (private) ─────────────────────────────────────────────
# Copy to .env and fill in. The .env file is git-ignored.

# Access control (REQUIRED for anything other than throwaway local use).
# If unset, the server generates a random token at boot and prints it.
TAX_ACCESS_TOKEN=

# Where to listen. Private by default (localhost). Only widen this behind
# your own authenticating proxy.
TAX_HOST=127.0.0.1
TAX_PORT=4000

# ── AI answers (/api/ask) ─────────────────────────────────────────────────
# Without a key, section lookup and search still work; only AI answers are off.
ANTHROPIC_API_KEY=
# Strong default; use claude-opus-4-8 for the hardest questions.
TAX_AI_MODEL=claude-sonnet-4-6
TAX_AI_MAX_TOKENS=1500
TAX_AI_TIMEOUT_MS=60000

# ── Official data sources ─────────────────────────────────────────────────
# Free key from https://api.data.gov/signup/ lifts govinfo's DEMO_KEY limits.
GOVINFO_API_KEY=DEMO_KEY
# Federal Register (IRS guidance) needs no key. CourtListener (case law) works
# without a token at a lower rate limit; a free token lifts it.
COURTLISTENER_API_TOKEN=

# Override only if you mirror/proxy these (defaults are the official hosts).
# GOVINFO_API_BASE=https://api.govinfo.gov
# CORNELL_BASE=https://www.law.cornell.edu
# ECFR_API_BASE=https://www.ecfr.gov
# FED_REGISTER_API_BASE=https://www.federalregister.gov
# COURTLISTENER_BASE=https://www.courtlistener.com

# ── Tuning ────────────────────────────────────────────────────────────────
# TAX_HTTP_TIMEOUT_MS=15000
# TAX_CACHE_MAX=500
# TAX_CACHE_TTL_MS=21600000
