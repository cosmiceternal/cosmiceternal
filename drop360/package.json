{
  "name": "drop360",
  "productName": "Drop360",
  "version": "0.1.0",
  "description": "Drag-and-drop Xbox 360 emulator app powered by the Xenia core",
  "main": "src/main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.cosmiceternal.drop360",
    "productName": "Drop360",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
