{
  "name": "discord-genre-radio",
  "version": "1.0.0",
  "description": "Multi-station Discord radio that streams long, uninterrupted music mixed by genre and production date, remote-controlled from Telegram.",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "check": "node --check src/index.js"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.13",
    "telegraf": "^4.16.3"
  }
}
