# ─────────────────────────────────────────────────────────────────────────────
#  Discord Genre Radio — configuration
#  Copy to ".env" and fill in. Every value is optional EXCEPT a token for at
#  least one station. A station only boots if its DISCORD_TOKEN_<ID> is set.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram remote control (optional but recommended) ───────────────────────
# Create a bot with @BotFather, paste its token here. Controls every station.
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs allowed to control the radio.
# Leave blank to allow anyone who can DM the bot (not recommended in public).
TELEGRAM_ALLOWED_USERS=

# ── Audio engine ─────────────────────────────────────────────────────────────
# Path to the yt-dlp binary. Default "yt-dlp" (must be on PATH).
#   Install: pipx install yt-dlp   (or)   brew install yt-dlp
YT_DLP_PATH=yt-dlp
# How many recently played tracks to avoid repeating, per station.
NO_REPEAT_WINDOW=12

# ─────────────────────────────────────────────────────────────────────────────
#  Per-station credentials. Each major genre is its OWN Discord bot so they can
#  all play in the same server at once. For each station you want to run, set:
#    DISCORD_TOKEN_<ID>   — bot token (from the Discord Developer Portal)
#    DISCORD_GUILD_<ID>   — the server (guild) ID the bot should play in
#    DISCORD_VOICE_<ID>   — the voice channel ID to join and stream into
#  IDs: ROCK POP HIPHOP ELECTRONIC RNB JAZZ METAL COUNTRY
# ─────────────────────────────────────────────────────────────────────────────

DISCORD_TOKEN_ROCK=
DISCORD_GUILD_ROCK=
DISCORD_VOICE_ROCK=

DISCORD_TOKEN_POP=
DISCORD_GUILD_POP=
DISCORD_VOICE_POP=

DISCORD_TOKEN_HIPHOP=
DISCORD_GUILD_HIPHOP=
DISCORD_VOICE_HIPHOP=

DISCORD_TOKEN_ELECTRONIC=
DISCORD_GUILD_ELECTRONIC=
DISCORD_VOICE_ELECTRONIC=

DISCORD_TOKEN_RNB=
DISCORD_GUILD_RNB=
DISCORD_VOICE_RNB=

DISCORD_TOKEN_JAZZ=
DISCORD_GUILD_JAZZ=
DISCORD_VOICE_JAZZ=

DISCORD_TOKEN_METAL=
DISCORD_GUILD_METAL=
DISCORD_VOICE_METAL=

DISCORD_TOKEN_COUNTRY=
DISCORD_GUILD_COUNTRY=
DISCORD_VOICE_COUNTRY=
