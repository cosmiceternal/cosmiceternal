# ============================================================
#  Godel Terminal — configuration
#  Copy to .env (or set these in your host's env) to enable
#  real market data. With no config it uses Yahoo Finance, and
#  falls back to a simulation engine if no provider is reachable.
# ============================================================

# Port to listen on
PORT=3001

# Which data provider to use:
#   auto        (default) try providers in order, fall back to simulation
#   yahoo       Yahoo Finance only (no key needed; best when run locally)
#   twelvedata  Twelve Data only (requires TWELVEDATA_API_KEY)
#   finnhub     Finnhub only (requires FINNHUB_API_KEY)
#   simulation  force the built-in simulation engine
DATA_PROVIDER=auto

# Free API keys — recommended for cloud/hosted deployments, where
# Yahoo Finance often blocks datacenter IP ranges.
#
#   Twelve Data — quotes + charts + search. Free tier: 800 req/day, 8/min.
#   Sign up: https://twelvedata.com/pricing  (free plan)
TWELVEDATA_API_KEY=

#   Finnhub — real-time quotes + market news. Free tier: 60 req/min.
#   Sign up: https://finnhub.io/register
FINNHUB_API_KEY=

# Set to false to disable the simulation fallback. When no real
# provider is reachable, data endpoints will return 503 instead of
# simulated data. Default: true.
ALLOW_SIMULATION=true
