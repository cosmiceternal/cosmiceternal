# Copy to .env and adjust. All values are optional — sensible defaults are used.

# Port the server listens on
PORT=3000

# --- Storage ---
# If DATABASE_URL is set, NEONSTAKE uses PostgreSQL (recommended in production
# so data persists — works great with free tiers like Neon or Render Postgres).
# Leave it unset for local dev and it falls back to SQLite automatically.
# DATABASE_URL=postgresql://user:password@host:5432/neonstake?sslmode=require

# SQLite database file (only used when DATABASE_URL is NOT set).
# Defaults to ./data/neonstake.db
DB_PATH=./data/neonstake.db

# Secret used to sign session cookies. If unset, one is generated and stored
# in the database on first run. Set this explicitly in production so sessions
# survive a fresh database / multiple instances.
SESSION_SECRET=

# --- Admin ---
# Username that automatically gets is_admin=1 at server startup. Pick your
# casino account name here. Once promoted, the player sees an "Admin"
# button in the topbar with a console for users / balances / audit log.
ADMIN_USERNAME=

# Starting play-money balance for new accounts, in whole currency units.
STARTING_BALANCE=1000

# Set to "1" to require secure (HTTPS-only) cookies. Enable in production.
SECURE_COOKIES=0

# --- Account lockout (failed-login protection) ---
LOCKOUT_THRESHOLD=5
LOCKOUT_WINDOW_MS=900000

# --- Rate limiting (per-IP fixed windows) ---
RATE_API_MAX=300
RATE_AUTH_MAX=40
RATE_DEALER_MAX=30

# --- AI Dealer (optional — falls back to scripted persona library when unset) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
DEALER_MODEL=claude-haiku-4-5

# --- Crypto vault ---
# Use 'playmoney' for the demo (deposits credit CRYPT instantly, no real funds).
# Switch to 'coinpayments' once the four COINPAYMENTS_* vars below are set and
# your IPN URL points at https://<your-host>/api/vault/webhook
VAULT_PROCESSOR=playmoney
DAILY_DEPOSIT_CAP_CRYPT=5000
MAX_PENDING_DEPOSITS=5

# CoinPayments credentials (only needed when VAULT_PROCESSOR=coinpayments).
# https://www.coinpayments.net/acct-api-keys
COINPAYMENTS_KEY=
COINPAYMENTS_SECRET=
COINPAYMENTS_IPN_SECRET=
COINPAYMENTS_MERCHANT_ID=
# Optional: override the IPN URL passed to CoinPayments when creating a deposit.
# COINPAYMENTS_IPN_URL=https://your-domain.example.com/api/vault/webhook
