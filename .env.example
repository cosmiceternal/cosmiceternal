# Copy to .env and adjust. All values are optional — sensible defaults are used.

# Port the server listens on
PORT=3000

# --- Storage ---
# If DATABASE_URL is set, NEONSTAKE uses PostgreSQL (recommended in production
# so data persists — works great with free tiers like Neon or Render Postgres).
# Leave it unset for local dev and it falls back to SQLite automatically.
# DATABASE_URL=postgresql://user:password@host:5432/neonstake?sslmode=require

# SQLite database file (only used when DATABASE_URL is NOT set).
# Defaults to ./data/neonstake.db
DB_PATH=./data/neonstake.db

# Secret used to sign session cookies. If unset, one is generated and stored
# in the database on first run. Set this explicitly in production so sessions
# survive a fresh database / multiple instances.
SESSION_SECRET=

# Starting play-money balance for new accounts, in whole currency units.
STARTING_BALANCE=1000

# Set to "1" to require secure (HTTPS-only) cookies. Enable in production.
SECURE_COOKIES=0
